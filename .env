# Frontend (Streamlit) port
STREAMLIT_PORT=8501

# Backend (FastAPI) port
BACKEND_PORT=8000
BACKEND_HOST=localhost

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/kraftit_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kraftit_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# ============================================
# APP CONFIGURATION
# ============================================
APP_NAME=Kraft-it
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_FILE_SIZE_MB=10
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
TEMP_FOLDER=temp

# ============================================
# SECURITY (Change in production!)
# ============================================
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501